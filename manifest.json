{
  "manifest_version": 3,
  "name": "AI Spell & Emoji",
  "version": "1.0.9",
  "description": "Умная проверка орфографии и подбор эмодзи через Gemini 3.1 Flash-Lite.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "AI Spell & Emoji",
    "default_icon": "icon128.png"
  },
  "commands": {
    "check_text_shortcut": {
      "suggested_key": {
        "default": "Alt+R",
        "mac": "Alt+R"
      },
      "description": "Проверить выделенный текст"
    },
    "suggest_emoji_shortcut": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "Подобрать эмодзи"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}